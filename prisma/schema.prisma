model Product {
  id     Int           @id @default(autoincrement())
  status ProductStatus
  name   String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  deletedAt DateTime?
  Mark      Mark?     @relation(fields: [markId], references: [id])
  markId    Int?
}

